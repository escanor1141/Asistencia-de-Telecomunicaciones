generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  documento        String            @id
  name             String
  email            String?
  correo2          String?
  whatsapp         String?
  telefono2        String?
  franja           String?
  programa         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  notificationLogs NotificationLog[]
  whatsappLogs     WhatsappNotificationLog[]
  courses          Course[]
}

model Course {
  id          String       @id @default(cuid())
  name        String
  code        String
  teacherId      String
  groupCode      String       @default("A")
  academicPeriod String       @default("1")
  academicYear   String       @default("2024")
  dia            String?
  horaInicio     String?
  horaFin        String?
  dia2           String?
  horaInicio2    String?
  horaFin2       String?
  franja         String?
  programa       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attendances    Attendance[]
  teacher        Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students       Student[]

  @@unique([code, groupCode, academicPeriod, academicYear, teacherId])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      String
  present   Boolean  @default(false)
  status    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [documento], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}

model Teacher {
  id           String   @id @default(cuid()) @map("id_docente")
  email        String   @unique @map("correo")
  passwordHash String   @map("contraseña")
  name         String   @map("nombre")
  role             String   @default("TEACHER") @map("rol")
  resetToken       String?  @map("token_recuperacion")
  resetTokenExpiry DateTime? @map("expiracion_token")
  createdAt        DateTime @default(now()) @map("fecha_creacion")
  courses      Course[]
}

model NotificationLog {
  id        String   @id @default(cuid())
  studentId String
  weekStart String
  sentAt    DateTime @default(now())
  status    String   @default("SUCCESS")
  error     String?
  student   Student  @relation(fields: [studentId], references: [documento], onDelete: Cascade)

  @@unique([studentId, weekStart])
}

model WhatsappNotificationLog {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      String
  sentAt    DateTime @default(now())
  status    String   @default("SUCCESS")
  error     String?
  student   Student  @relation(fields: [studentId], references: [documento], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}
