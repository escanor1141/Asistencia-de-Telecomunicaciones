generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Student {
  id               String            @id @default(cuid())
  name             String
  email            String?
  whatsapp         String?
  courseId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  notificationLogs NotificationLog[]
  whatsappLogs     WhatsappNotificationLog[]
  course           Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Course {
  id          String       @id @default(cuid())
  name        String
  code        String
  teacherId      String
  groupCode      String       @default("A")
  academicPeriod String       @default("1")
  academicYear   String       @default("2024")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  attendances    Attendance[]
  teacher        Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students       Student[]

  @@unique([code, groupCode, academicPeriod, academicYear, teacherId])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      String
  present   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}

model Teacher {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("TEACHER")
  createdAt    DateTime @default(now())
  courses      Course[]
}

model NotificationLog {
  id        String   @id @default(cuid())
  studentId String
  weekStart String
  sentAt    DateTime @default(now())
  status    String   @default("SUCCESS")
  error     String?
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, weekStart])
}

model WhatsappNotificationLog {
  id        String   @id @default(cuid())
  studentId String
  courseId  String
  date      String
  sentAt    DateTime @default(now())
  status    String   @default("SUCCESS")
  error     String?
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId, date])
}
