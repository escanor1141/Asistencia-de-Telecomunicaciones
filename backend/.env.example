DATABASE_URL="postgresql://usuario:password@localhost:5432/nombre_db?schema=public"

# ── Brevo Email API ──────────────────────────────────────────────
# Obtén tu API Key en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=tu_api_key_aca
BREVO_SENDER_EMAIL=tu_email@ejemplo.com
BREVO_SENDER_NAME="Tu Nombre o Sistema"
WEEKLY_REPORT_RECIPIENT_EMAIL=correo_de_reporte@ejemplo.com
WEEKLY_REPORT_RECIPIENT_NAME="Administrador de Asistencia"

# ── Evolution API (WhatsApp) ────────────────────────────────────
EVOLUTION_API_URL=http://localhost:5000
EVOLUTION_API_KEY=tu_api_key_evolution
EVOLUTION_INSTANCE=nombre_instancia
WHATSAPP_SEND_DELAY_MS=5000
 
# JWT (firmado para tokens de sesión)
# Genera un secreto fuerte: `openssl rand -base64 32` o similar
JWT_SECRET=tu_secreto_jwt_aqui
